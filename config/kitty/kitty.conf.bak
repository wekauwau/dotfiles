include current-theme.conf
font_size 11.5

cursor_shape block
cursor_stop_blinking_after 0

scrollback_lines 2000

copy_on_select yes

mouse_hide_wait 0

# select_by_word_characters @-./_~? &
# =%+#a

enable_audio_bell no
bell_on_tab "🔔 "

remember_window_size no
window_border_width 1pt
draw_minimal_borders yes

window_padding_width 10

inactive_text_alpha 0.6

hide_window_decorations yes

confirm_os_window_close 0

tab_bar_style powerline

background_opacity 1.0

# font_family      family='JetBrainsMono Nerd Font' style=Light
# bold_font        auto
# italic_font      family='JetBrainsMono Nerd Font' style='Light Italic'
# bold_italic_font auto

# BEGIN_KITTY_FONTS
font_family      family='JetBrainsMono Nerd Font' style=Regular
bold_font        auto
italic_font      family='JetBrainsMono Nerd Font' style=Italic
bold_italic_font auto
# END_KITTY_FONTS
