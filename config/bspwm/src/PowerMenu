#!/usr/bin/env bash

options=(
  "َ°چپ"
  "ï††"
  "َ°—½"
  "َ°œ‰"
  "َ°گ¥"
)

rofi_cmd() {
  rofi -dmenu \
    -p "Goodbye ${USER}" \
    -mesg "Uptime: $(uptime -p | sed -e 's/up //g')" \
    -no-click-to-exit \
    -theme "$HOME"/.config/bspwm/src/rofi-themes/PowerMenu.rasi
}

chosen=$(printf "%s\n" "${options[@]}" | rofi_cmd)

case $chosen in
"َ°چپ")
  betterlockscreen -l
  ;;
"ï††")
  # mpc -q pause
  # amixer set Master mute
  systemctl suspend
  ;;
"َ°—½")
  bspc quit
  ;;
"َ°œ‰")
  systemctl reboot
  ;;
"َ°گ¥")
  systemctl poweroff
  ;;
esac
