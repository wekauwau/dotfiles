#!/usr/bin/env bash
set -euo pipefail

OUTPUT="${1:-$(basename "$PWD").pdf}"
if [[ "${1:-}" == *.pdf ]]; then
  shift
fi
TMPDIR="$(mktemp -d)"

NATURAL_SORT=false
NO_ALPHA_CHECK=false
QUALITY=85
WIDTH=""
MAX_HEIGHT=""

cleanup() {
  rm -rf "$TMPDIR"
}
trap cleanup EXIT

# Parse flags
for arg in "$@"; do
  case "$arg" in
  -n | --natural)
    NATURAL_SORT=true
    ;;
  -A | --no-alpha-check)
    NO_ALPHA_CHECK=true
    ;;
  -q=*)
    QUALITY="${arg#*=}"
    ;;
  --width=*)
    WIDTH="${arg#*=}"
    ;;
  --max-height=*)
    MAX_HEIGHT="${arg#*=}"
    ;;
  *)
    echo "Unknown option: $arg" >&2
    exit 1
    ;;
  esac
done

shopt -s nullglob
GLOBS=(*.png *.jpg *.jpeg *.webp *.avif)

if ((${#GLOBS[@]} == 0)); then
  echo "No images found."
  exit 1
fi

# Sorting
if $NATURAL_SORT; then
  mapfile -d '' -t IMAGES < <(printf '%s\0' "${GLOBS[@]}" | sort -z -V)
else
  IMAGES=("${GLOBS[@]}")
fi

FINAL_IMAGES=()

echo "Processing images..."

for img in "${IMAGES[@]}"; do
  needs_flatten=false

  if ! $NO_ALPHA_CHECK; then
    opaque=$(magick identify -format "%[opaque]" "$img" || echo "True")
    if [[ "$opaque" == "False" ]]; then
      needs_flatten=true
    fi
  fi

  # Build output path only if needed
  if $needs_flatten || [[ -n "$WIDTH" || -n "$MAX_HEIGHT" ]]; then
    base="$(basename "${img%.*}")"
    out="$TMPDIR/$base.jpg"

    resize_args=()

    # Enlarge without upscale
    # -resize "${WIDTH}x<"
    if [[ -n "$WIDTH" && -n "$MAX_HEIGHT" ]]; then
      resize_args=(-resize "${WIDTH}x${MAX_HEIGHT}")
    elif [[ -n "$WIDTH" ]]; then
      resize_args=(-resize "${WIDTH}x")
    elif [[ -n "$MAX_HEIGHT" ]]; then
      resize_args=(-resize "x${MAX_HEIGHT}>")
    fi

    echo "Converting: $img"

    magick "$img" \
      -background white -alpha remove -alpha off \
      "${resize_args[@]}" \
      -strip -interlace Plane \
      -quality "$QUALITY" \
      "$out"

    FINAL_IMAGES+=("$out")
  else
    # Keep original (no recompression)
    FINAL_IMAGES+=("$img")
  fi
done

echo "Creating PDF: $OUTPUT"
img2pdf "${FINAL_IMAGES[@]}" -o "$OUTPUT"

echo "Done: $OUTPUT"
